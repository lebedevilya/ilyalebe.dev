---
import TimeLineElement from "./TimeLine.astro";
import type { CVData } from "../../data/cv";

interface Props {
  cv: CVData;
}

const { cv } = Astro.props;
---

<div class="mb-5">
  <div class="text-3xl font-bold">{cv.headline}</div>
</div>

<div class="mb-10">
  {cv.personalInfo.map((item) => (
    <div>
      <b>{item.label}:</b> {item.value}
    </div>
  ))}
</div>

<div class="mb-5">
  <div class="text-3xl font-bold">Contact</div>
</div>

<div class="mb-10">
  {cv.contact.map((item) => (
    <div>
      <b>{item.label}:</b>&nbsp;
      {item.href ? <a href={item.href}>{item.value}</a> : item.value}
    </div>
  ))}
</div>

<div class="mb-5">
  <div class="text-3xl font-bold">Profile</div>
</div>

<div class="mb-10 text-justify">
  {cv.profile}
</div>

<div class="mb-5">
  <div class="text-3xl font-bold">Experience</div>
</div>

<div class="time-line-container mb-5">
  {cv.experience.map((entry) => (
    <TimeLineElement title={entry.title} subtitle={entry.subtitle}>
      {entry.bullets ? (
        <ul class="list-disc mx-6 mb-2 grid gap-2">
          {entry.bullets.map((bullet) => (
            <li>{bullet}</li>
          ))}
        </ul>
      ) : entry.body ? (
        <>
          {entry.body}
        </>
      ) : null}
      {entry.tech ? (
        <span class="text-sm font-light">
          Tech: {entry.tech}
        </span>
      ) : null}
    </TimeLineElement>
  ))}
</div>

<div class="mb-5">
  <div class="text-3xl font-bold">Education & Programs</div>
</div>

<div class="time-line-container grid gap-4 mb-10">
  {cv.education.map((entry) => (
    <TimeLineElement title={entry.title} subtitle={entry.subtitle}>
      {entry.body ? (
        <p class="max-w-3xl leading-relaxed">
          {entry.body}
        </p>
      ) : null}
    </TimeLineElement>
  ))}
</div>

<div class="mb-5">
  <div class="text-3xl font-bold">Selected Projects</div>
</div>

<div class="time-line-container mb-10">
  {cv.projects.map((project) => (
    <TimeLineElement title={project.title}>
      <p class="max-w-3xl leading-relaxed">
        {project.body}
        {project.href ? (
          <>
            &nbsp;
            <a href={project.href}>{project.linkLabel ?? project.href}</a>
          </>
        ) : null}
      </p>
    </TimeLineElement>
  ))}
</div>

<div class="mb-5">
  <div class="text-3xl font-bold">Core Skills</div>
</div>

<ul class="list-disc md:columns-3 columns-2 mx-6 mb-10">
  {cv.skills.map((skill) => (
    <li>
      <b>{skill.label}:</b> {skill.value}
    </li>
  ))}
</ul>
