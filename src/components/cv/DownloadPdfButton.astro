---
// CV "Download as PDF" button. Calls window.print() and relies on the print
// stylesheet in src/styles/global.css to strip chrome (sidebar, theme toggle,
// footer) and tighten typography so the output fits two pages.
// The button itself is hidden in the print output via `print:hidden`.
---

<div class="flex justify-end mb-4 print:hidden">
  <button
    type="button"
    onclick="window.print()"
    class="btn btn-sm btn-outline gap-2"
    aria-label="Download CV as PDF"
    title="Open print preview; choose 'Save as PDF' to download"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
      <polyline points="7 10 12 15 17 10"></polyline>
      <line x1="12" y1="15" x2="12" y2="3"></line>
    </svg>
    Download PDF
  </button>
</div>
