---
// Floating "Download as PDF" button, pinned below the theme toggle in the
// top-right of the viewport. Calls window.print(); the print stylesheet in
// global.css strips chrome and the title-blanking listener in BaseHead
// suppresses the browser-injected page title header.
// The button itself is hidden from the print output via `print:hidden`.
---

<button
  type="button"
  onclick="window.print()"
  class="btn btn-md fixed top-20 right-4 z-50 bg-base-100/70 backdrop-blur border border-base-300 shadow-md hover:bg-base-200 gap-2 print:hidden"
  aria-label="Download CV as PDF"
  title="Open print preview; choose 'Save as PDF' to download"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
    <polyline points="7 10 12 15 17 10"></polyline>
    <line x1="12" y1="15" x2="12" y2="3"></line>
  </svg>
  Download PDF
</button>
