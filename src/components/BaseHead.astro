---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';

export interface Props {
	title: string;
	description: string;
	image?: string;
}

const { title, description, image = '/profile.png' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site ?? Astro.url);
const siteRoot = (Astro.site ?? Astro.url).toString().replace(/\/$/, "");

// Pick OG type and the profile-specific meta block based on the route.
const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";
const ogType = isHome ? "profile" : "website";

// JSON-LD: Person + WebSite + (on the homepage) ProfilePage. Search and
// answer engines (Google, Perplexity, ChatGPT search) preferentially index
// pages that ship structured data describing the entity.
const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"@id": `${siteRoot}/#person`,
	"name": "Ilya Lebedev",
	"givenName": "Ilya",
	"familyName": "Lebedev",
	"url": siteRoot,
	"image": new URL("/profile.png", Astro.site ?? Astro.url).toString(),
	"jobTitle": "Senior Fullstack Engineer & Technical Founder",
	"description": "Senior software engineer with 8+ years building and scaling production SaaS systems end-to-end. Ex-founder (Techstars Web3 '25): scaled an infrastructure-heavy platform to 18k+ users and 25k+ deployed nodes. Hands-on with LLM orchestration, RAG pipelines and AI coding tools; comfortable picking up any stack.",
	"sameAs": [
		"https://github.com/lebedevilya",
		"https://www.linkedin.com/in/ilya-lebedev-554225102/",
		"https://www.instagram.com/ilyalebe.dev/",
		"https://www.youtube.com/channel/UCxdLFTIk7QMlunmCy4uC_Pw",
		"https://t.me/rubyminer"
	],
	"knowsAbout": [
		"Ruby on Rails", "TypeScript", "LLM orchestration", "RAG", "Web3",
		"Solidity", "PostgreSQL", "Vercel", "OpenAI", "Hotwire", "React"
	]
};

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"@id": `${siteRoot}/#website`,
	"url": siteRoot,
	"name": "Ilya Lebedev",
	"description": "Personal website and CV of Ilya Lebedev.",
	"author": { "@id": `${siteRoot}/#person` }
};

const profilePageSchema = {
	"@context": "https://schema.org",
	"@type": "ProfilePage",
	"url": siteRoot,
	"mainEntity": { "@id": `${siteRoot}/#person` }
};

const schemaGraph = {
	"@context": "https://schema.org",
	"@graph": isHome
		? [personSchema, websiteSchema, profilePageSchema]
		: [personSchema, websiteSchema]
};
---

<!-- Theme bootstrap (runs before first paint to avoid flash of wrong theme) -->
<script is:inline>
  (function () {
    var STORAGE_KEY = "theme";
    var LIGHT = "lofi";
    var DARK = "dark";

    function stored() {
      try {
        var saved = localStorage.getItem(STORAGE_KEY);
        if (saved === LIGHT || saved === DARK) return saved;
      } catch (_) {}
      return null;
    }

    function osPreferred() {
      return matchMedia("(prefers-color-scheme: dark)").matches ? DARK : LIGHT;
    }

    function currentTheme() {
      return stored() || osPreferred();
    }

    // Apply only updates the DOM; persistence is separate so OS-derived
    // values do not get frozen into localStorage on first visit.
    function apply(theme) {
      document.documentElement.setAttribute("data-theme", theme);
    }

    function persist(theme) {
      try { localStorage.setItem(STORAGE_KEY, theme); } catch (_) {}
    }

    // Initial paint: explicit choice wins; otherwise follow OS without persisting.
    apply(currentTheme());

    // Toggle button: this is the only path that writes to localStorage,
    // so a first-time visitor who never clicks the button keeps following
    // their OS preference across sessions and OS-theme changes.
    window.__toggleTheme = function () {
      var next = document.documentElement.getAttribute("data-theme") === DARK ? LIGHT : DARK;
      apply(next);
      persist(next);
    };

    // Auto-follow OS theme for visitors who never picked one.
    matchMedia("(prefers-color-scheme: dark)").addEventListener("change", function (e) {
      if (!stored()) apply(e.matches ? DARK : LIGHT);
    });

    // View Transitions caveat: every page ships with <html data-theme="lofi">
    // as a no-JS fallback. When ClientRouter swaps to a new page, the
    // incoming document's html attributes override the live ones, so any
    // dark-theme choice would flash back to lofi on navigation. Patch the
    // incoming document before the swap so the user never sees the flash.
    document.addEventListener("astro:before-swap", function (event) {
      event.newDocument.documentElement.setAttribute("data-theme", currentTheme());
    });

    // Blank the document title during print so the browser doesn't inject
    // it as a page header at the top of every printed page (Chrome shows
    // it when 'Headers and footers' is on in the print dialog, which is
    // the default). Restored after the print dialog closes.
    var titleBeforePrint = "";
    window.addEventListener("beforeprint", function () {
      titleBeforePrint = document.title;
      document.title = " ";
    });
    window.addEventListener("afterprint", function () {
      if (titleBeforePrint) document.title = titleBeforePrint;
    });
  })();
</script>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22256%22 height=%22256%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2250%22 fill=%22%23ffb1e7%22></rect><text x=%2250%%22 y=%2250%%22 dominant-baseline=%22central%22 text-anchor=%22middle%22 font-size=%2290%22>🚀</text></svg>" />
<meta name="generator" content={Astro.generator} />
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
{isHome && (
	<>
		<meta property="og:profile:first_name" content="Ilya" />
		<meta property="og:profile:last_name" content="Lebedev" />
		<meta property="og:profile:username" content="lebedevilya" />
	</>
)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

<!-- Structured data -->
<script type="application/ld+json" set:html={JSON.stringify(schemaGraph)} />
