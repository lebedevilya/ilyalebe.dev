---
import type { Project } from "../data/projects";

type Props = Project;

const {
  title,
  img,
  tagline,
  longDesc,
  stack,
  role,
  badge,
  badgeClass = "badge-secondary",
  links = [],
} = Astro.props;

const isDiscontinued = badge === "DISCONTINUED";
---

<details
  class:list={[
    "group rounded-lg bg-base-100",
    isDiscontinued ? "opacity-70" : "transition ease-in-out hover:shadow-xl",
  ]}
>
  <summary
    class="hero-content flex-col gap-4 md:flex-row cursor-pointer list-none [&::-webkit-details-marker]:hidden"
  >
    {
      img && (
        <img
          src={img}
          width="750"
          height="422"
          loading="lazy"
          decoding="async"
          alt={title}
          class="max-w-full md:max-w-[13rem] rounded-lg"
        />
      )
    }
    <div class="grow w-full">
      <h1 class="text-xl font-bold">
        {title}
        {badge && <div class={`badge ${badgeClass} mx-2`}>{badge}</div>}
      </h1>
      <p class="py-1">{tagline}</p>
      {role && <p class="py-1 text-sm font-light">{role}</p>}
    </div>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="size-5 shrink-0 self-center opacity-60 transition-transform duration-200 group-open:rotate-180"
      aria-hidden="true"
    >
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </summary>

  <div class="px-6 pb-5 md:px-8">
    <p class="leading-relaxed">{longDesc}</p>
    {stack && <p class="mt-2 text-sm font-light">Stack: {stack}</p>}
    {
      links.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {links.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="btn btn-sm">
              {link.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</details>
