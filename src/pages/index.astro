---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { visitedCountries } from "../data/travel";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="lg:mt-4 lg:px-20">
    <div class="text-xl py-1">Hey there 👋</div>
    <h1 class="text-5xl font-bold">I'm Ilya Lebedev</h1>
    <p class="text-3xl py-3 font-bold">Software Engineer and Technical founder</p>

    <!-- Currently -->
    <div class="card bg-base-200 my-5">
      <div class="card-body p-5">
        <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
          <span class="relative flex h-3 w-3" aria-hidden="true">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-success"></span>
          </span>
          <span class="font-bold">Currently:</span>
          <span>open to senior fullstack contract work and technical co-founder conversations.</span>
        </div>
      </div>
    </div>

    <!-- Tech stack badges -->
    <div class="my-5">
      <div class="text-sm font-semibold opacity-75 mb-2">Working with:</div>
      <div class="flex flex-wrap gap-1.5">
        <img alt="Ruby on Rails" src="https://img.shields.io/badge/rails-%23CC0000.svg?style=flat-square&logo=rubyonrails&logoColor=white" />
        <img alt="TypeScript" src="https://img.shields.io/badge/typescript-%23007ACC.svg?style=flat-square&logo=typescript&logoColor=white" />
        <img alt="Hotwire" src="https://img.shields.io/badge/Hotwire-Turbo%2BStimulus-yellow?style=flat-square" />
        <img alt="React" src="https://img.shields.io/badge/react-%2320232a.svg?style=flat-square&logo=react&logoColor=%2361DAFB" />
        <img alt="PostgreSQL" src="https://img.shields.io/badge/postgres-%23316192.svg?style=flat-square&logo=postgresql&logoColor=white" />
        <img alt="OpenAI" src="https://img.shields.io/badge/OpenAI-412991?style=flat-square&logo=openai&logoColor=white" />
        <img alt="Solidity" src="https://img.shields.io/badge/solidity-%23363636.svg?style=flat-square&logo=solidity&logoColor=white" />
        <img alt="Vercel" src="https://img.shields.io/badge/vercel-%23000000.svg?style=flat-square&logo=vercel&logoColor=white" />
        <img alt="AWS" src="https://img.shields.io/badge/AWS-%23FF9900.svg?style=flat-square&logo=amazon-aws&logoColor=white" />
        <img alt="Docker" src="https://img.shields.io/badge/docker-%230db7ed.svg?style=flat-square&logo=docker&logoColor=white" />
        <img alt="TailwindCSS" src="https://img.shields.io/badge/tailwindcss-%2338B2AC.svg?style=flat-square&logo=tailwind-css&logoColor=white" />
      </div>
    </div>

    <div class="divider my-2"></div>

    <div class="py-2">
      <p class="text-lg">
        I love to build products with real impact to the world. My main speciality is Ruby on Rails development and I'm constantly seeking opportunities to expand my knowledge and stay at the forefront of the tech landscape.
      </p>
    </div>
    <div class="divider my-0"></div>
    <div class="py-2">
      <p class="text-lg">
        Besides web development, I'm in web3 space for a long time: I've been mining ETH since 2016 until The Merge happened, managing 250+ GPUs.
      </p>
    </div>
    <div class="divider my-0"></div>
    <div class="py-2">
      <p class="text-lg">
        I have a few other passions that keep me inspired. I enjoy traveling, and so far, I've had the pleasure of exploring {visitedCountries.length} countries (with many more on my list). When I'm not immersed in coding, you can find me playing ping-pong, flying FPV drone or playing board games.
        I really love diving; I'm a certified scuba diver (PADI Advanced) and freediver (Molchanov Wave 1).
      </p>
    </div>

  <div class="pt-2">
    <div class="divider my-0"></div>
    <div class="pt-2">
      <p class="text-lg">
        Subscribe to Instagram:
        <a class="bg-gradient-to-tr from-yellow-400 to-fuchsia-600 text-transparent bg-clip-text" href="https://www.instagram.com/ilyalebe.dev/">
          @ilyalebe.dev
        </a>
      </p>
      <p class="text-lg">
        Youtube channel:
        <a class="bg-gradient-to-tr from-red-400 to-fuchsia-600 text-transparent bg-clip-text" href="https://www.youtube.com/channel/UCxdLFTIk7QMlunmCy4uC_Pw">
          @ilya0lebedev
        </a>
      </p>

    </div>
  </div>

  <div class="mt-10 mb-20">
    <div class="-my-4 flex justify-center gap-5 overflow-hidden py-4 sm:gap-8">
      <div class="relative aspect-[9/10] w-44 flex-none overflow-hidden rounded-xl sm:w-72 sm:rounded-2xl rotate-2">
        <img src="/pic1.jpeg" loading="lazy" decoding="async" alt="Travel photo 1" class="absolute inset-0 h-full w-full object-cover" style="color:transparent" sizes="(min-width: 640px) 18rem, 11rem">
      </div>
      <div class="relative aspect-[9/10] w-44 flex-none overflow-hidden rounded-xl sm:w-72 sm:rounded-2xl -rotate-2">
        <img src="/pic2.jpeg" loading="lazy" decoding="async" alt="Travel photo 2" class="absolute inset-0 h-full w-full object-cover" style="color:transparent" sizes="(min-width: 640px) 18rem, 11rem">
      </div>
      <div class="relative aspect-[9/10] w-44 flex-none overflow-hidden rounded-xl sm:w-72 sm:rounded-2xl rotate-2">
        <img src="/pic3.jpeg" loading="lazy" decoding="async" alt="Travel photo 3" class="absolute inset-0 h-full w-full object-cover" style="color:transparent" sizes="(min-width: 640px) 18rem, 11rem">
      </div>
    </div>
  </div>

  <div class="lg:px-28">
    <h2 class="text-3xl w-full font-bold mb-8">My last projects {"</>"}</h2>

    <HorizontalCard
      title="SupportOS"
      img="/supportos.png"
      desc="Agentic support for startup portfolios"
      url="https://supportos.ilyalebe.dev"
      badge="LIVE"
      badgeClass="badge-success"
      role="Creator"
    />
    <br>
    <HorizontalCard
      title="slack-llm-bot"
      img="/slack-llm-bot.png"
      desc="Production-shaped Slack bot on Vercel. OpenAI tool-loop with threaded memory and an offline eval harness so the LLM behaviour is tested like real software. TypeScript."
      url="https://github.com/lebedevilya/slack-llm-bot"
      badge="OSS"
      role="Creator"
    />
    <br>
    <HorizontalCard
      title="nodes.garden"
      img="/nodes.png"
      desc="Multichain Node as a Service Provider. Finalist of Backdrop Build V4, V5 and V6. Completed founder.university Cohort 9. Now in Techstars Web3 2025."
      url="https://nodes.garden"
      badge="LIVE"
      badgeClass="badge-success"
      role="Co-Founder"
    />
    <br>
    <HorizontalCard
      title="customs.codes"
      img="/codes1.png"
      desc="AI powered tool for searching HS codes. Built during Backdrop Build V3 contest and reached finals."
      url="https://customs.codes"
      role="Creator"
      badge="DISCONTINUED"
      badgeClass="badge-error"
    />
    <br>
    <HorizontalCard
      title="souper.cafe"
      img="/souper.jpeg"
      desc="Kitchen & Tiki bar in Tbilisi, Georgia"
      url="https://souper.cafe/"
      role="Co-Founder"
      badge="DISCONTINUED"
      badgeClass="badge-error"
    />
    <div class="divider my-2"></div>
  </div>
</BaseLayout>
