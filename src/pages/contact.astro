---
import BaseLayout from "../layouts/BaseLayout.astro";

const calendlyUrl = "https://calendly.com/ilya0lebedev/30min";
---

<BaseLayout
  title="Contact | Ilya Lebedev"
  description="How to reach Ilya Lebedev: book a 30-minute intro call, or message via LinkedIn, Telegram, or GitHub."
  sideBarActiveItemID="contact"
>
  <div class="lg:px-20 lg:mt-4 max-w-3xl">
    <h1 class="text-5xl font-bold">Contact</h1>
    <p class="text-lg py-4 max-w-prose">
      Currently open to senior fullstack contract work and technical co-founder conversations. Pick whichever channel fits.
    </p>

    <!-- Primary: book a call -->
    <a
      href={calendlyUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="block group"
    >
      <div class="card bg-primary text-primary-content my-6 transition hover:shadow-xl hover:scale-[101%]">
        <div class="card-body">
          <div class="flex items-center gap-3">
            <span class="text-3xl" aria-hidden="true">📅</span>
            <h2 class="card-title text-2xl">Book a 30-minute call</h2>
          </div>
          <div class="card-actions justify-end">
            <span class="btn btn-sm">Open Calendly →</span>
          </div>
        </div>
      </div>
    </a>

    <div class="grid gap-4">
      <a
        href="https://www.linkedin.com/in/ilya-lebedev-554225102/"
        target="_blank"
        rel="noopener noreferrer"
        class="card bg-base-200 transition hover:shadow-lg hover:scale-[101%]"
      >
        <div class="card-body">
          <div class="flex items-center gap-2">
            <span class="text-2xl" aria-hidden="true">💼</span>
            <h3 class="card-title">LinkedIn DM</h3>
          </div>
        </div>
      </a>

      <a
        href="https://t.me/rubyminer"
        target="_blank"
        rel="noopener noreferrer"
        class="card bg-base-200 transition hover:shadow-lg hover:scale-[101%]"
      >
        <div class="card-body">
          <div class="flex items-center gap-2">
            <span class="text-2xl" aria-hidden="true">💬</span>
            <h3 class="card-title">Telegram</h3>
          </div>
        </div>
      </a>

      <a
        href="https://github.com/lebedevilya"
        target="_blank"
        rel="noopener noreferrer"
        class="card bg-base-200 transition hover:shadow-lg hover:scale-[101%]"
      >
        <div class="card-body">
          <div class="flex items-center gap-2">
            <span class="text-2xl" aria-hidden="true">💻</span>
            <h3 class="card-title">GitHub</h3>
          </div>
        </div>
      </a>
    </div>
  </div>
</BaseLayout>
