---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CVPage from "../../components/cv/CVPage.astro";
import { getCVVariant, getCVVariantSlugs, isCVVariantSlug } from "../../data/cv";

export function getStaticPaths() {
  return getCVVariantSlugs()
    .filter((slug) => slug !== "general")
    .map((variant) => ({ params: { variant } }));
}

const variantParam = Astro.params.variant;
if (!variantParam || !isCVVariantSlug(variantParam) || variantParam === "general") {
  throw new Error(`Unknown CV variant: ${variantParam}`);
}

const cv = getCVVariant(variantParam);
if (!cv) {
  throw new Error(`Missing CV variant data: ${variantParam}`);
}
---

<BaseLayout title={cv.title} sideBarActiveItemID="cv">
  <CVPage cv={cv} />
</BaseLayout>
