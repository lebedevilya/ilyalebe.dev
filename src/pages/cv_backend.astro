---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
import DownloadPdfButton from "../components/cv/DownloadPdfButton.astro";

const arbitrumGrantUrl = "https://arbitrum.questbook.app/dashboard/?grantId=67d7ff7f46da2f90cc3205e9&role=community&chainId=10&proposalId=68d6c5b2306fa3a0a647b6bb&isRenderingProposalBody=true";
const techstarsWeb3Url = "https://www.techstars.com/newsroom/announcing-the-techstars-web3-class-of-2025";
---

<BaseLayout title="Backend Resume | Ilya Lebedev" description="Senior Backend Engineer resume of Ilya Lebedev. Ruby on Rails depth, distributed systems, async pipelines, Web3 infrastructure. Ex-founder, Techstars Web3 '25." sideBarActiveItemID="cv" mainClass="cv-page">

  <DownloadPdfButton />

  <!-- PERSONAL INFO -->
  <div class="mb-5">
    <h1 class="text-3xl font-bold">Senior Backend Engineer</h1>
  </div>

  <div class="mb-10">
    <b>Name:</b> Ilya Lebedev<br>
    <b>Location:</b> Remote (US/EU time zones), B2B contract<br>
    <b>Languages:</b> Russian (Native), English (C2), Spanish (A1)
  </div>

  <!-- CONTACT -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Contact</h2>
  </div>

  <div class="mb-10">
    <b>Website:</b>&nbsp;<a href="https://ilyalebe.dev">ilyalebe.dev</a><br>
    <b>Email:</b> ilya0lebedev@gmail.com<br>
    <b>LinkedIn:</b>&nbsp;<a href="https://www.linkedin.com/in/ilya-lebedev-554225102/">ilya-lebedev-554225102</a><br>
    <b>Telegram:</b> @rubyminer<br>
    <b>GitHub:</b>&nbsp;<a href="https://github.com/lebedevilya">lebedevilya</a>
  </div>

  <!-- PROFILE -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Profile</h2>
  </div>

  <div class="mb-10 text-justify">
    Senior backend engineer with 8+ years of experience building & scaling Ruby on Rails applications.
    Ex-founder (<a href={techstarsWeb3Url}>Techstars Web3 '25</a>): built and scaled an infrastructure-heavy platform to 18,000+ users and 25,000+ deployed nodes, secured an <a href={arbitrumGrantUrl}>Arbitrum ecosystem grant</a>, and implemented Node NFT smart contracts and marketplace.
    Strong experience with PostgreSQL, background processing, integrations and performance optimization.
    Experienced in owning backend systems end-to-end, from architecture and data modeling to deployment, monitoring and scaling.
  </div>

  <!-- EXPERIENCE -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Experience</h2>
  </div>

  <div class="time-line-container mb-5">
    <!-- NODES.GARDEN -->
    <TimeLineElement
      title="Backend Engineer / Founder"
      subtitle="Mar 2025 – Feb 2026 — nodes.garden (remote)"
    >
      <ul class="list-disc mx-6 mb-2 grid gap-2">
        <li>Founded and led the backend architecture of a Web3/AI platform built with Ruby on Rails and PostgreSQL.</li>
        <li>Built APIs, async jobs and internal tooling for managing large-scale infrastructure. 25,000+ nodes deployed in a year.</li>
        <li>Scaled the platform from 0 to 18,000+ users and $350k yearly revenue.</li>
        <li>Secured an <a href={arbitrumGrantUrl}>Arbitrum ecosystem grant</a> and implemented Node NFT smart contracts and marketplace.</li>
        <li>Owned domain modeling, failure handling, background processing and data consistency.</li>
        <li>Built browser automation and data collection workflows with proxy handling, retries and failure recovery.</li>
        <li>Assembled and managed a distributed team of 10 people including engineers, customer support and operations.</li>
        <li>Completed <a href={techstarsWeb3Url}>Techstars Web3 2025</a>, XFounders Season 4 and Founder.University Cohort 9 programs.</li>
      </ul>
      <span class="text-sm font-light">
        Tech: Ruby on Rails, PostgreSQL, RSpec, GoodJob, Hotwire, TailwindCSS, Solidity, Foundry, OpenZeppelin, ethers.js, MetaMask, JSON-RPC, Arbitrum, Docker, fly.io
      </span>
    </TimeLineElement>

    <!-- REINVENTED HOSPITALITY -->
    <TimeLineElement
      title="Backend Ruby Engineer"
      subtitle="Aug 2024 – Mar 2025 — reinvented-hospitality.com (remote)"
    >
      <ul class="list-disc mx-6 mb-2 grid gap-2">
        <li>Built the backend for a full-cycle POS system in Ruby on Rails with a strong focus on operational reliability.</li>
        <li>Designed and delivered domain logic for restaurant and hotel workflows, including reporting and exports.</li>
        <li>Delivered background jobs and data flows that supported daily business operations.</li>
      </ul>
      <span class="text-sm font-light">
        Tech: Ruby on Rails, PostgreSQL, Sidekiq, Hotwire, MiniTest, TailwindCSS, ViewComponent, AWS, Docker
      </span>
    </TimeLineElement>

    <!-- XOMETRY -->
    <TimeLineElement
      title="Backend Ruby Engineer"
      subtitle="Aug 2022 – Aug 2024 — xometry.de (remote)"
    >
      <ul class="list-disc mx-6 mb-2 grid gap-2">
        <li>Helped scale backend architecture for a global manufacturing marketplace supporting transactions across hundreds of thousands of buyers and suppliers.</li>
        <li>Implemented and launched UK and TR regional apps under tight deadlines.</li>
        <li>Built an AI-powered HS codes search tool that cut code search time for the logistics team by 90%+.</li>
        <li>Designed and implemented async intercompany communication systems with background processing and data consistency.</li>
        <li>Fully owned and managed Salesforce integrations and data pipelines.</li>
        <li>Built foundational domain systems for HS codes, manufacturing attributes, and pricing logic.</li>
      </ul>
      <span class="text-sm font-light">
        Tech: Ruby on Rails, ReactJS, RSpec, PostgreSQL, Sidekiq, GraphQL, RabbitMQ, Redis, Python, Airflow
      </span>
    </TimeLineElement>

    <!-- EARLIER EXPERIENCE -->
    <TimeLineElement
      title="Backend Ruby Engineer"
      subtitle="2019 – 2021 at sputnik8.com, igooods.ru, rubyroidlabs.com (remote)"
    >
      Backend development across e-commerce, travel, insurance and internal tooling products, with ownership of integrations, data flows, and production support.
      <br>
      <span class="text-sm font-light">
        Tech: Ruby on Rails, ReactJS, VueJS, RSpec, PostgreSQL, Sidekiq, GraphQL, REST APIs, Heroku, AWS
      </span>
    </TimeLineElement>

    <TimeLineElement
      title="Internships & Early Career"
      subtitle="2017 – 2019"
    >
      <ul class="list-disc mx-6 mb-2 grid gap-2">
        <li>
          Yandex: Web Developer Intern. Python, ReactJS, GraphQL.
        </li>
        <li>
          Joint Institute for Nuclear Research: C++/CUDA Developer Intern.
        </li>
        <li>
          WorldQuant: Quantitative Research Consultant.
        </li>
      </ul>
    </TimeLineElement>
  </div>

  <!-- EDUCATION -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Education & Programs</h2>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="XFounders Season 4"
      subtitle="2025 — x-founders.com"
    >
      <p class="max-w-3xl leading-relaxed">
        1 month on-site program involving dozens of startups and mentors, organized with Starknet Foundation
      </p>
    </TimeLineElement>
    <TimeLineElement
      title="Techstars Web3 '25"
      subtitle="2025 — techstars.com"
    >
      <p class="max-w-3xl leading-relaxed">
        Selected for <a href={techstarsWeb3Url}>Techstars Web3 '25</a>; scaled the business and pitched with on-site deep dives in Dublin & London
      </p>
    </TimeLineElement>
    <TimeLineElement
      title="Master's Degree in Applied Mathematics and Computer Science"
      subtitle="2017–2019 — Saint Petersburg State University"
    />
    <TimeLineElement
      title="Bachelor's Degree in Applied Mathematics and Computer Science"
      subtitle="2013–2017 — Saint Petersburg State University"
    />
  </div>

  <!-- PROJECTS -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Selected Projects</h2>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement title="slack-llm-bot">
      <p class="max-w-3xl leading-relaxed">
        Slack bot deployed as Vercel functions (TypeScript). HMAC signature verification, ack-within-3-seconds + async post-ack work via <code>waitUntil</code>, OpenAI tool-loop with a deterministic stats block prepended to LLM tool results, threaded memory via the Slack API, and optional Supabase pgvector for cross-thread recall. Offline LLM eval harness ships with the repo:&nbsp;
        <a href="https://github.com/lebedevilya/slack-llm-bot">github.com/lebedevilya/slack-llm-bot</a>
      </p>
    </TimeLineElement>

    <TimeLineElement title="nodes.garden">
      <p class="max-w-3xl leading-relaxed">
        Web3/AI NaaS platform built with Ruby on Rails; secured an <a href={arbitrumGrantUrl}>Arbitrum ecosystem grant</a> and implemented Node NFT smart contracts and marketplace. Finalist of Backdrop Build V4–V6:&nbsp;
        <a href="https://backdropbuild.com/builds/nodesgarden">backdropbuild.com/builds/nodesgarden</a>
      </p>
    </TimeLineElement>

    <TimeLineElement title="customs.codes">
      <p class="max-w-3xl leading-relaxed">
        RAG customs codes AI classification tool built with Ruby on Rails. Finalist of Backdrop Build V3:&nbsp;
        <a href="https://backdropbuild.com/builds/v3/customscodes">backdropbuild.com/builds/v3/customscodes</a>
      </p>
    </TimeLineElement>
  </div>

  <!-- SKILLS -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Core Skills</h2>
  </div>

  <ul class="list-disc md:columns-3 columns-2 mx-6 mb-10">
    <li><b>Languages:</b> Ruby, Javascript, Python</li>
    <li><b>Backend:</b> Ruby on Rails, ActiveRecord, REST/GraphQL APIs, distributed systems, domain modeling</li>
    <li><b>Web3:</b> Solidity, ERC-721, Foundry, OpenZeppelin, ethers.js, JSON-RPC</li>
    <li><b>Databases:</b> PostgreSQL, Redis</li>
    <li><b>Async:</b> Sidekiq, GoodJob, SolidQueue, RabbitMQ</li>
    <li><b>Infra:</b> Docker, CI/CD, AWS, GCP, fly.io, Heroku, Kamal</li>
    <li><b>Observability:</b> Datadog, Sentry, Appsignal</li>
    <li><b>Integrations:</b> Salesforce, Stripe, PayPal, CloudPayments, Copperx, LLM integrations</li>
    <li><b>Automation:</b> Browser automation, scraping, CAPTCHA bypassing</li>
    <li><b>Frontend:</b> Hotwire, ReactJS, ViewComponent, TailwindCSS</li>
  </ul>

</BaseLayout>
