---
import BaseLayout from "../layouts/BaseLayout.astro";
import CVPage from "../components/cv/CVPage.astro";
import { getCVVariant } from "../data/cv";

const cv = getCVVariant("general");

if (!cv) {
  throw new Error("Missing CV variant: general");
}
---

<BaseLayout title={cv.title} sideBarActiveItemID="cv">
  <CVPage cv={cv} />
</BaseLayout>
